# Application database (matches docker-compose)
DATABASE_URL=postgresql+psycopg://agentops:agentops_dev@localhost:5432/agentops

# Langfuse (self-hosted)
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# LLM provider: anthropic | openai | google | ollama | fake
LLM_PROVIDER_NAME=fake
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Optional: override Gemini model. Default is gemini-2.5-flash.
# gemini-2.5-pro has stronger tool-calling but slower / more expensive.
GEMINI_MODEL=gemini-2.5-flash
# OPENAI_API_KEY is read directly by flows2agents.llm.openai if you choose openai
# OLLAMA_HOST defaults to http://localhost:11434 (set if your Ollama is elsewhere)
